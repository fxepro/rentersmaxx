APP_NAME=Rentersmaxx
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://rentersmaxx.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rentersmaxx
DB_USERNAME=rentersmaxx
DB_PASSWORD=

# ── Cache / Session / Queue ──
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@rentersmaxx.com
MAIL_FROM_NAME="Rentersmaxx"

# ── Payment Processors ──
# Stripe (US, EU, UK, AU, SG, JP, CA)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Razorpay (India)
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Flutterwave (Africa)
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Xendit (Southeast Asia)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Mercado Pago (Latin America)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Storage ──
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rentersmaxx-documents
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── FX / Currency ──
# Exchange rate API key (e.g. exchangerate-api.com or openexchangerates.org)
FX_API_KEY=
FX_API_URL=https://v6.exchangerate-api.com/v6

# ── Vite ──
VITE_APP_NAME="${APP_NAME}"
